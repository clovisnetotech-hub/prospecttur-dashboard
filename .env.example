# Copie este arquivo para .env e preencha com os valores do painel do Supabase
# (Project Settings → API)

# Geral / n8n
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-publishable-aqui

# Astro (prefixo PUBLIC_ obrigatório no client)
PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sua-chave-publishable-aqui

# Secreta — use SOMENTE no n8n/server-side (UPSERT, nunca no browser)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui
