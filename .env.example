# Copie este arquivo para .env e preencha com os valores do painel do Supabase
# (Project Settings → API)

# Públicas — podem ser usadas no navegador (prefixo PUBLIC_ obrigatório no Astro)
PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Secreta — use SOMENTE em código server-side (nunca no browser)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui
