---
import '../styles/global.css';
import { getSupabase, type Lead } from '../lib/supabase';

const supabase = getSupabase();

let leads: Lead[] = [];
let error: { message: string } | null = null;

if (!supabase) {
	error = { message: 'Configure PUBLIC_SUPABASE_URL e PUBLIC_SUPABASE_ANON_KEY no arquivo .env' };
} else {
	const result = await supabase
		.from('leads')
		.select('id, razao_social, cnae, instagram, lead_score, justificativa_ia')
		.order('lead_score', { ascending: false });

	if (result.error) {
		error = result.error;
	} else {
		leads = (result.data ?? []) as Lead[];
	}
}

function scoreStyle(score: number): string {
	if (score >= 80) return 'bg-emerald-100 text-emerald-800 ring-emerald-200';
	if (score >= 60) return 'bg-amber-100 text-amber-800 ring-amber-200';
	return 'bg-rose-100 text-rose-800 ring-rose-200';
}
---

<html lang="pt-BR">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Prospecttur — prospecção inteligente de leads para agências de viagens." />
		<title>Prospecttur — Leads de Agências de Viagens</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen bg-slate-50 font-[Inter,sans-serif] text-slate-900 antialiased">
		<div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
			<header class="mb-10 text-center">
				<div
					class="mx-auto mb-4 inline-flex items-center gap-2 rounded-full bg-indigo-50 px-4 py-1.5 text-sm font-medium text-indigo-700 ring-1 ring-indigo-100"
				>
					<span class="h-2 w-2 rounded-full bg-indigo-500"></span>
					Prospecção inteligente
				</div>
				<h1
					class="bg-gradient-to-r from-indigo-600 via-violet-600 to-indigo-800 bg-clip-text text-4xl font-bold tracking-tight text-transparent sm:text-5xl"
				>
					Prospecttur
				</h1>
				<p class="mx-auto mt-4 max-w-xl text-lg text-slate-600">
					Leads qualificados de agências de viagens — prontos para o seu time comercial.
				</p>
			</header>

			<section
				class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm shadow-slate-200/60"
			>
				<div class="flex items-center justify-between border-b border-slate-100 px-6 py-4">
					<div>
						<h2 class="text-base font-semibold text-slate-900">Pipeline de Leads</h2>
						<p class="text-sm text-slate-500">{leads.length} agências mapeadas</p>
					</div>
					<span class="rounded-lg bg-indigo-50 px-3 py-1 text-xs font-medium text-indigo-700 ring-1 ring-indigo-100">
						Supabase
					</span>
				</div>

				{
					error && (
						<div class="border-b border-rose-100 bg-rose-50 px-6 py-4 text-sm text-rose-700">
							Não foi possível carregar os leads: {error.message}
						</div>
					)
				}

				<div class="overflow-x-auto">
					<table class="w-full min-w-[720px] text-left text-sm">
						<thead>
							<tr class="border-b border-slate-100 bg-slate-50/80">
								<th class="px-6 py-3.5 font-semibold text-slate-700">Razão Social</th>
								<th class="px-6 py-3.5 font-semibold text-slate-700">CNAE</th>
								<th class="px-6 py-3.5 font-semibold text-slate-700">Instagram</th>
								<th class="px-6 py-3.5 font-semibold text-slate-700">Lead Score</th>
								<th class="px-6 py-3.5 font-semibold text-slate-700">Justificativa IA</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-slate-100">
							{
								leads.length === 0 && !error ? (
									<tr>
										<td colspan="5" class="px-6 py-8 text-center text-slate-500">
											Nenhum lead encontrado na tabela <code class="text-slate-700">leads</code>.
										</td>
									</tr>
								) : (
									leads.map((lead) => (
										<tr class="transition-colors hover:bg-slate-50/80">
											<td class="px-6 py-4 font-medium text-slate-900">{lead.razao_social}</td>
											<td class="px-6 py-4 font-mono text-xs text-slate-600">{lead.cnae}</td>
											<td class="px-6 py-4">
												{lead.instagram ? (
													<a
														href={lead.instagram}
														target="_blank"
														rel="noopener noreferrer"
														class="inline-flex items-center gap-1.5 text-indigo-600 hover:text-indigo-800 hover:underline"
													>
														<svg
															class="h-3.5 w-3.5 shrink-0"
															fill="currentColor"
															viewBox="0 0 24 24"
															aria-hidden="true"
														>
															<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
														</svg>
														Ver perfil
													</a>
												) : (
													<span class="text-slate-400">—</span>
												)}
											</td>
											<td class="px-6 py-4">
												<span
													class={`inline-flex min-w-[3rem] items-center justify-center rounded-full px-2.5 py-1 text-xs font-bold ring-1 ${scoreStyle(lead.lead_score)}`}
												>
													{lead.lead_score}
												</span>
											</td>
											<td class="max-w-xs px-6 py-4 text-slate-600">{lead.justificativa_ia ?? '—'}</td>
										</tr>
									))
								)
							}
						</tbody>
					</table>
				</div>
			</section>

			<footer class="mt-8 text-center text-sm text-slate-400">
				© {new Date().getFullYear()} Prospecttur. Todos os direitos reservados.
			</footer>
		</div>
	</body>
</html>
