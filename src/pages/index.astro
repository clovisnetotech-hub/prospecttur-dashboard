---
import '../styles/global.css';
import { getSupabase, LEADS_QUERY, type Lead } from '../lib/supabase';

let initialLeads: Lead[] = [];
let initialError: string | null = null;

const supabase = getSupabase();

if (!supabase) {
	initialError = 'Credenciais do Supabase nao configuradas.';
} else {
	const { data, error } = await supabase
		.from('leads')
		.select(LEADS_QUERY)
		.order('lead_score', { ascending: false });

	if (error) {
		initialError = error.message;
	} else {
		initialLeads = (data ?? []) as Lead[];
	}
}

const cnaes = [...new Set(initialLeads.map((lead) => lead.cnae).filter(Boolean))].sort();
const initialPayload = JSON.stringify({
	initialLeads,
	initialError,
	supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL ?? '',
	supabaseAnonKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '',
});
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta
			name="description"
			content="Dashboard de inteligencia comercial da Prospecttur para agencias de viagens."
		/>
		<title>Prospecttur - Inteligencia Comercial para Agencias de Viagens</title>
	</head>
	<body class="min-h-screen bg-slate-50 text-slate-950 antialiased">
		<main class="mx-auto flex min-h-screen w-full max-w-7xl flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
			<header class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
				<div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
					<div>
						<p class="text-xs font-semibold uppercase tracking-[0.18em] text-indigo-600">
							Prospeccao B2B
						</p>
						<h1 class="mt-2 bg-gradient-to-r from-indigo-600 via-violet-600 to-fuchsia-600 bg-clip-text text-4xl font-bold tracking-normal text-transparent sm:text-5xl">
							Prospecttur
						</h1>
						<p class="mt-3 text-base text-slate-600 sm:text-lg">
							Inteligencia Comercial para Agencias de Viagens
						</p>
					</div>

					<div class="flex flex-col gap-3 sm:flex-row sm:items-center">
						<div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
							<p class="text-xs font-medium uppercase tracking-wide text-slate-500">Leads</p>
							<p id="lead-count" class="mt-1 text-2xl font-bold text-slate-950">
								{initialLeads.length} leads qualificados
							</p>
						</div>
						<button
							id="refresh-btn"
							type="button"
							class="inline-flex h-11 items-center justify-center gap-2 rounded-lg bg-slate-950 px-4 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-60"
						>
							<svg
								id="refresh-icon"
								class="h-4 w-4"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								aria-hidden="true"
							>
								<path stroke-linecap="round" stroke-linejoin="round" d="M20 11a8.1 8.1 0 0 0-15.5-2M4 5v4h4" />
								<path stroke-linecap="round" stroke-linejoin="round" d="M4 13a8.1 8.1 0 0 0 15.5 2M20 19v-4h-4" />
							</svg>
							<span id="refresh-label">Atualizar Dados</span>
						</button>
					</div>
				</div>
			</header>

			<section
				id="error-banner"
				class:list={[
					'rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-700',
					initialError ? '' : 'hidden',
				]}
			>
				<div class="flex gap-3">
					<svg class="mt-0.5 h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.3 3.9 2.6 17.2A2 2 0 0 0 4.3 20h15.4a2 2 0 0 0 1.7-2.8L13.7 3.9a2 2 0 0 0-3.4 0Z" />
					</svg>
					<p>
						<strong class="font-semibold">Nao foi possivel carregar os leads.</strong>
						<span id="error-message">{initialError}</span>
					</p>
				</div>
			</section>

			<section class="rounded-lg border border-slate-200 bg-white shadow-sm">
				<div class="border-b border-slate-200 p-4 sm:p-6">
					<div class="flex flex-col gap-4 lg:flex-row lg:items-end">
						<div class="flex-1">
							<label for="search-input" class="text-xs font-medium uppercase tracking-wide text-slate-500">
								Buscar por razao social
							</label>
							<div class="relative mt-1.5">
								<svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.3-4.3m1.3-5.2a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z" />
								</svg>
								<input
									id="search-input"
									type="search"
									placeholder="Digite o nome da agencia..."
									class="h-11 w-full rounded-lg border border-slate-200 bg-white pl-9 pr-3 text-sm shadow-sm outline-none transition placeholder:text-slate-400 focus:border-indigo-300 focus:ring-4 focus:ring-indigo-100"
								/>
							</div>
						</div>

						<div class="grid gap-4 sm:grid-cols-2 lg:w-[28rem]">
							<div>
								<label for="score-filter" class="text-xs font-medium uppercase tracking-wide text-slate-500">
									Score
								</label>
								<select
									id="score-filter"
									class="mt-1.5 h-11 w-full rounded-lg border border-slate-200 bg-white px-3 text-sm shadow-sm outline-none transition focus:border-indigo-300 focus:ring-4 focus:ring-indigo-100"
								>
									<option value="all">Todos os scores</option>
									<option value="high">Alta >= 80</option>
									<option value="medium">Media 50-79</option>
									<option value="low">Baixa &lt; 50</option>
								</select>
							</div>

							<div>
								<label for="cnae-filter" class="text-xs font-medium uppercase tracking-wide text-slate-500">
									CNAE
								</label>
								<select
									id="cnae-filter"
									class="mt-1.5 h-11 w-full rounded-lg border border-slate-200 bg-white px-3 text-sm shadow-sm outline-none transition focus:border-indigo-300 focus:ring-4 focus:ring-indigo-100"
								>
									<option value="all">Todos os CNAEs</option>
									{cnaes.map((cnae) => <option value={cnae}>{cnae}</option>)}
								</select>
							</div>
						</div>
					</div>
				</div>

				<div id="table-wrapper" class="overflow-x-auto">
					<table class="w-full min-w-[920px] text-left text-sm">
						<thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
							<tr>
								<th class="px-4 py-3 font-semibold sm:px-6">Razao Social</th>
								<th class="px-4 py-3 font-semibold sm:px-6">CNAE</th>
								<th class="px-4 py-3 font-semibold sm:px-6">Instagram</th>
								<th class="px-4 py-3 font-semibold sm:px-6">Lead Score</th>
								<th class="px-4 py-3 font-semibold sm:px-6">Justificativa IA</th>
								<th class="px-4 py-3 font-semibold sm:px-6">Acoes</th>
							</tr>
						</thead>
						<tbody id="leads-tbody" class="divide-y divide-slate-100">
							<tr>
								<td colspan="6" class="px-6 py-16 text-center text-sm text-slate-500">
									Carregando leads...
								</td>
							</tr>
						</tbody>
					</table>
				</div>
			</section>
		</main>

		<script id="initial-leads-data" type="application/json" set:html={initialPayload} />
		<script>
			import { initLeadsDashboard } from '../scripts/leads-dashboard';

			const payloadEl = document.getElementById('initial-leads-data');
			const payload = payloadEl?.textContent
				? JSON.parse(payloadEl.textContent)
				: { initialLeads: [], initialError: 'Dados iniciais indisponiveis.' };

			initLeadsDashboard(payload);
		</script>
	</body>
</html>
